<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <link rel="stylesheet" href="menu.css">
    <style>
:root {
  --hex-size: clamp(70px, 10vw, 140px);
  --hex-gap: clamp(8px, 1.5vw, 18px);
  --handle-height: 70px;
}

/* FONT ONLY (menu handles global text now) */
@font-face {
  font-family: "UD Digi Kyokasho";
  src: url("UD Digi Kyokasho NP-B.ttf");
}

/* =========================
   BASE LAYOUT
========================= */

body {
  background-color: #4a281c;
  background-image: url("HomeBackground.png");
  background-repeat: no-repeat;
  background-attachment: fixed;
  background-size: contain;
  background-position: center;

  margin: 0;
  min-height: 100vh;

  display: flex;
  justify-content: center;
  align-items: center;
}

body.menu-open {
  overflow: hidden;
}

/* =========================
   CENTER PIECE
========================= */

.CenterPiece {
  position: relative;
  display: inline-block;
  text-align: center;
}

.CenterImage img {
  width: clamp(200px, 50vw, 550px);
  height: auto;
}

.Name {
  position: absolute;
  top: 0;
  left: 0;
  transform: translate(-80%, 100%);
  font-size: clamp(18px, 3vw, 45px);
}

.JobTitle {
  position: absolute;
  bottom: 0;
  right: 0;
  transform: translate(90%, -80%);
  font-size: clamp(18px, 3vw, 45px);
}
    </style>
  </head>
  <body>
    <!-- PAGE CONTENT -->
    <div class="CenterPiece">
      <div class="Name">Enkel Cipa</div>
      <div class="CenterImage"> <img src="PicOfMe.png"> </div>
      <div class="JobTitle"> Gameplay and<br>
        Technical Designer </div>
    </div>
    <!-- REUSABLE MENU MOUNT POINT -->
    <div id="menu-container"></div>
    <!-- MENU SYSTEM SCRIPT -->
    <script src="menu.js"></script>
  </body>
</html>
