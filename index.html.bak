<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Home</title>

<style>
:root {
  --hex-size: clamp(70px, 10vw, 140px);
  --hex-gap: clamp(8px, 1.5vw, 18px);
  --handle-height: 70px;
}

/* =========================
   GLOBAL FONT + TEXT STYLE
========================= */

@font-face {
  font-family: "UD Digi Kyokasho";
  src: url("UD Digi Kyokasho NP-B.ttf");
}

/* APPLY TO EVERYTHING */
* {
  font-family: "UD Digi Kyokasho", sans-serif;
  color: white;

  text-shadow:
    -3px -3px 5px #4A281C,
     3px -3px 5px #4A281C,
    -3px  3px 5px #4A281C,
     3px  3px 5px #4A281C;
}

/* =========================
   BASE LAYOUT (DESKTOP)
========================= */

body {
  background-color: #4a281c;
  background-image: url("HomeBackground.png");
  background-repeat: no-repeat;
  background-attachment: fixed;
  background-size: contain;
  background-position: center;

  margin: 0;
  min-height: 100vh;

  display: flex;
  justify-content: center;
  align-items: center;
}

body.menu-open {
  overflow: hidden;
}

/* =========================
   CENTER PIECE (DESKTOP)
========================= */

.CenterPiece {
  position: relative;
  display: inline-block;
  text-align: center;
}

.CenterImage img {
  width: clamp(200px, 50vw, 550px);
  height: auto;
}

.Name {
  position: absolute;
  top: 0;
  left: 0;
  transform: translate(-80%, 100%);
  font-size: clamp(18px, 3vw, 45px);
}

.JobTitle {
  position: absolute;
  bottom: 0;
  right: 0;
  transform: translate(90%, -80%);
  font-size: clamp(18px, 3vw, 45px);
}

/* =========================
   MENU PANEL
========================= */

.MenuPanel {
  width: 420px;
  max-width: 90vw;
  height: 100vh;

  background: url("MenuPanelBackground.png") no-repeat center/cover;
  background-color: #4a281c;

  display: flex;
  justify-content: center;
  align-items: center;
}

/* =========================
   HEX GRID
========================= */

.HexGrid {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: var(--hex-gap);
}

.hex-col {
  display: flex;
  flex-direction: column;
  gap: var(--hex-gap);
}

.hex-col.offset {
  margin-top: 0;
}

/* =========================
   HEX BUTTONS
========================= */

.HexBrown,
.HexOrange {
  width: var(--hex-size);
  height: var(--hex-size);

  display: flex;
  justify-content: center;
  align-items: center;

  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;

  font-size: clamp(12px, 2.5vw, 20px);
  text-decoration: none;

  transition: transform 0.2s ease;
}

.HexBrown { background-image: url("HexFilledBrown.png"); }
.HexOrange { background-image: url("HexFilledOrange.png"); }

.HexBrown:hover,
.HexOrange:hover {
  transform: scale(1.05);
}

/* =========================
   DESKTOP MENU
========================= */

.DesktopMenu {
  position: fixed;
  top: 0;
  right: -420px;
  height: 100vh;

  display: flex;
  flex-direction: row;

  transition: right 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  z-index: 1000;
}

.DesktopMenu.active {
  right: 0;
}

.DesktopHandle {
  width: 70px;
  height: 100vh;

  display: flex;
  justify-content: center;
  align-items: center;

  background: #4a281c;
}

.MenuPanelButton {
  width: 50px;
  cursor: pointer;
  transition: transform 0.3s ease;
}

.DesktopMenu.active .MenuPanelButton {
  transform: rotate(180deg);
}

/* =========================
   MOBILE SYSTEM
========================= */

.MobileHandle,
.MobileMenu {
  display: none;
}

@media (max-width: 768px) {

  /* HARD LOCK SCROLL (IMPORTANT FIX) */
  html, body {
    height: 100%;
    width: 100%;
    overflow: hidden;
    position: fixed;
    overscroll-behavior: none;
  }

  body {
    background-size: cover;
    background-position: center;
    background-attachment: scroll;
  }

  /* CENTER PIECE MOBILE */
  .CenterPiece {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;

    position: static;
    width: 100%;
    height: 100vh;
  }

  .Name,
  .JobTitle {
    position: static;
    transform: none;
  }

  .Name {
    margin-bottom: 30px;
    font-size: clamp(26px, 6vw, 42px);
  }

  .JobTitle {
    margin-top: 30px;
    font-size: clamp(22px, 5vw, 36px);
  }

  /* HIDE DESKTOP */
  .DesktopMenu {
    display: none;
  }

  /* MOBILE HANDLE */
  .MobileHandle {
    display: flex;
    position: fixed;
    top: 0;
    left: 0;

    width: 100%;
    height: var(--handle-height);

    justify-content: center;
    align-items: center;

    background: #4a281c;
    z-index: 3000;
  }

  .MobileHandle img {
    width: 40px;
    transform: rotate(-90deg);
    transition: transform 0.3s ease;
  }

  .MobileMenu.active ~ .MobileHandle img {
    transform: rotate(90deg);
  }

  /* MOBILE MENU FULL WIDTH */
  .MobileMenu {
    display: flex;
    position: fixed;

    top: var(--handle-height);
    left: 0;

    width: 100vw;
    height: calc(100vh - var(--handle-height));

    transform: translateY(-100%);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);

    z-index: 2000;

    margin: 0;
    padding: 0;
  }

  .MobileMenu.active {
    transform: translateY(0);
  }

  .MobileMenu .MenuPanel {
    width: 100%;
    max-width: 100%;
    height: 100%;
  }

  .HexGrid {
    flex-direction: column;
    --hex-size: clamp(110px, 20vw, 190px);
  }

  .hex-col.offset {
    margin-top: 0;
  }
  
  .MobileMenu .hex-col:nth-child(1) a:nth-child(1),
  .MobileMenu .hex-col:nth-child(2) a:nth-child(2)
  {
    background-image: url("HexFilledOrange.png");
  }
  .MobileMenu .hex-col:nth-child(1) a:nth-child(2),
  .MobileMenu .hex-col:nth-child(2) a:nth-child(1)
  {
    background-image: url("HexFilledBrown.png");
  }
  .MobileMenu .hex-col:nth-child(1) a:nth-child(3) {
    background-image: url("HexFilledOrange.png");
  }
}
</style>
</head>

<body>

<div class="CenterPiece">
  <div class="Name">Enkel Cipa</div>
  <div class="CenterImage">
    <img src="PicOfMe.png">
  </div>
  <div class="JobTitle">Gameplay and<br>Technical Designer</div>
</div>

<!-- DESKTOP -->
<div id="DesktopMenu" class="DesktopMenu">
  <div class="DesktopHandle">
    <img src="MenuPanelButton.png" class="MenuPanelButton" onclick="toggleDesktopMenu()">
  </div>

  <div class="MenuPanel">
    <div class="HexGrid">
      <div class="hex-col">
        <a href="index.html" class="HexBrown">Home</a>
        <a href="About.html" class="HexBrown">About</a>
        <a href="" class="HexBrown">CV</a>
      </div>

      <div class="hex-col offset">
        <a href="Projects.html" class="HexOrange">Projects</a>
        <a href="LinkedIn" class="HexOrange">LinkedIn</a>
      </div>
    </div>
  </div>
</div>

<!-- MOBILE -->
<div id="MobileMenu" class="MobileMenu">
  <div class="MenuPanel">
    <div class="HexGrid">
      <div class="hex-col">
        <a href="index.html" class="HexBrown">Home</a>
        <a href="About.html" class="HexBrown">About</a>
        <a href="" class="HexBrown">CV</a>
      </div>

      <div class="hex-col offset">
        <a href="Projects.html" class="HexOrange">Projects</a>
        <a href="LinkedIn" class="HexOrange">LinkedIn</a>
      </div>
    </div>
  </div>
</div>

<div class="MobileHandle">
  <img src="MenuPanelButton.png" onclick="toggleMobileMenu()">
</div>

<script>
function toggleDesktopMenu() {
  document.getElementById("DesktopMenu").classList.toggle("active");
}

function toggleMobileMenu() {
  const menu = document.getElementById("MobileMenu");
  menu.classList.toggle("active");
  document.body.classList.toggle("menu-open");
}
</script>

</body>
</html>